# Firebase Realtime Database config for 1v1 multiplayer.
# Copy this file to `.env.local` (gitignored) and fill in your project's values
# from Firebase console → Project settings → General → "Your apps" (Web app),
# plus the Realtime Database URL from the Realtime Database page.
#
# Only these keys are needed (Vite exposes vars prefixed with VITE_ to the client).
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
